#!/bin/bash
set -e

# =========================
# Rune paths
# =========================

RUNE_HOME="$HOME/.rune"
RUNE_BIN="$RUNE_HOME/bin"
RUNE_EXEC="$RUNE_BIN/rune"
RUNE_DIR="$RUNE_HOME/runes"

RUNE_VERSION="0.6.0"
RUNE_REPO_RAW_URL="https://raw.githubusercontent.com/zeidle/rune/main"

mkdir -p "$RUNE_BIN"
mkdir -p "$RUNE_DIR"

command="$1"
target="$2"
shift 2 2>/dev/null || true

# =========================
# Helpers
# =========================

get_field() {
  grep "^$1:" "$2" | cut -d' ' -f2-
}

print_block() {
  awk "/^$1: \|/{flag=1;next}/^[^ ]/{flag=0}flag" "$2" \
    | sed 's/^  //' \
    | sed 's/^/    /'
}

get_requires() {
  local file="$1"

  awk '
    /^requires:[[:space:]]*$/ {
      flag=1
      next
    }

    /^[^[:space:]]/ {
      flag=0
    }

    flag && /^[[:space:]]*-/ {
      sub(/^[[:space:]]*-[[:space:]]*/, "")
      print
    }
  ' "$file" || true
}

check_requires() {
  local file="$1"
  local deps
  local missing=0

  deps=$(get_requires "$file")

  while IFS= read -r dep; do
    [ -z "$dep" ] && continue

    if ! command -v "$dep" >/dev/null 2>&1; then
      if [ "$missing" -eq 0 ]; then
        echo "❌ Missing dependencies:"
      fi

      echo "  $dep"
      missing=$((missing + 1))
    fi
  done <<< "$deps"

  if [ "$missing" -gt 0 ]; then
    return 1
  fi

  return 0
}

doctor_ok() {
  echo "✅ $1"
}

doctor_warn() {
  echo "⚠️  $1"
}

doctor_fail() {
  echo "❌ $1"
}

is_valid_rune_name() {
  local name="$1"

  [[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]]
}

is_supported_runtime() {
  local runtime="$1"

  case "$runtime" in
    bash|python|node|ruby|swift|go)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

validate_field() {
  local field="$1"
  local file="$2"
  local value

  value=$(get_field "$field" "$file")

  if [ -n "$value" ]; then
    doctor_ok "field exists: $field"
    return 0
  else
    doctor_fail "missing field: $field"
    return 1
  fi
}

block_exists() {
  local field="$1"
  local file="$2"

  if grep -q "^$field: |" "$file"; then
    doctor_ok "block exists: $field"
    return 0
  else
    doctor_warn "missing block: $field"
    return 1
  fi
}

validate_rune_quiet() {
  local target="$1"
  local dir="$RUNE_DIR/$target"
  local yaml="$dir/rune.yaml"
  local errors=0
  local name
  local runtime
  local entry
  local schema_version
  local entry_path
  local deps

  if [ ! -d "$dir" ]; then
    return 1
  fi

  if [ ! -f "$yaml" ]; then
    return 1
  fi

  schema_version=$(get_field schema_version "$yaml")
  name=$(get_field name "$yaml")
  runtime=$(get_field runtime "$yaml")
  entry=$(get_field entry "$yaml")

  [ -z "$schema_version" ] && errors=$((errors + 1))
  [ -z "$name" ] && errors=$((errors + 1))
  [ -z "$runtime" ] && errors=$((errors + 1))
  [ -z "$entry" ] && errors=$((errors + 1))

  if [ -n "$schema_version" ] && [ "$schema_version" != "1" ]; then
    errors=$((errors + 1))
  fi

  if [ -n "$name" ] && [ "$name" != "$target" ]; then
    errors=$((errors + 1))
  fi

  if [ -n "$runtime" ] && ! is_supported_runtime "$runtime"; then
    errors=$((errors + 1))
  fi

  if [ -z "$entry" ]; then
    entry="run"
  fi

  entry_path="$dir/$entry"

  if [ ! -f "$entry_path" ]; then
    errors=$((errors + 1))
  fi

  if [ -f "$entry_path" ] && [ ! -x "$entry_path" ]; then
    errors=$((errors + 1))
  fi

  deps=$(get_requires "$yaml")

  if [ -n "$deps" ]; then
    while IFS= read -r dep; do
      [ -z "$dep" ] && continue

      if ! command -v "$dep" >/dev/null 2>&1; then
        errors=$((errors + 1))
      fi
    done <<< "$deps"
  fi

  if [ "$errors" -eq 0 ]; then
    return 0
  else
    return 1
  fi
}

print_global_help() {
  echo ""
  echo "Rune CLI $RUNE_VERSION"
  echo "=================================="
  echo ""
  echo "Usage:"
  echo "  rune <command> [options]"
  echo ""
  echo "Core:"
  echo "  add                    Create a new rune"
  echo "  list                   List available runes"
  echo "  run <name> [args...]   Run a rune"
  echo "  help <name>            Show help for a rune"
  echo "  edit <name>            Edit rune entry file"
  echo "  edit <name> --config   Edit rune.yaml"
  echo "  edit <name> --all      Open rune directory"
  echo "  remove <name>          Delete rune with confirmation"
  echo "  remove <name> --force  Delete rune without confirmation"
  echo "  path <name>            Print rune directory path"
  echo "  open <name>            Open rune directory"
  echo ""
  echo "Diagnostics:"
  echo "  info <name>            Show rune metadata and status"
  echo "  validate <name>        Validate rune manifest and structure"
  echo "  doctor                 Check Rune installation"
  echo ""
  echo "Maintenance:"
  echo "  update                 Update Rune CLI"
  echo "  version                Show Rune version"
  echo ""
  echo "Examples:"
  echo "  rune add"
  echo "  rune list"
  echo "  rune run ios-run --scheme App"
  echo "  rune help ios-run"
  echo "  rune info ios-run"
  echo "  rune validate ios-run"
  echo "  rune doctor"
  echo "  rune update"
  echo "  rune version"
  echo "  rune path ios-run"
  echo "  rune open ios-run"
  echo ""
}

# =========================
# Commands
# =========================

case "$command" in

  ""|--help|-h)
    print_global_help
    ;;

  version|--version|-v)
    echo "Rune $RUNE_VERSION"
    ;;

  path)
    if [ -z "$target" ]; then
      echo "❌ Missing rune name."
      echo "Run:"
      echo "  rune list"
      exit 1
    fi

    dir="$RUNE_DIR/$target"

    if [ ! -d "$dir" ]; then
      echo "❌ Rune not found: $target"
      exit 1
    fi

    echo "$dir"
    ;;

  open)
    if [ -z "$target" ]; then
      echo "❌ Missing rune name."
      echo "Run:"
      echo "  rune list"
      exit 1
    fi

    dir="$RUNE_DIR/$target"

    if [ ! -d "$dir" ]; then
      echo "❌ Rune not found: $target"
      exit 1
    fi

    if command -v open >/dev/null 2>&1; then
      open "$dir"
    elif command -v xdg-open >/dev/null 2>&1; then
      xdg-open "$dir"
    else
      echo "Could not open directory automatically."
      echo ""
      echo "Path:"
      echo "  $dir"
      exit 1
    fi
    ;;

  doctor)
    echo ""
    echo "Rune Doctor"
    echo "=================================="
    echo ""

    echo "Version:"
    echo "  Rune $RUNE_VERSION"
    echo ""

    echo "Paths:"
    echo "  RUNE_HOME: $RUNE_HOME"
    echo "  RUNE_BIN:  $RUNE_BIN"
    echo "  RUNE_EXEC: $RUNE_EXEC"
    echo "  RUNE_DIR:  $RUNE_DIR"
    echo ""

    echo "Update source:"
    echo "  $RUNE_REPO_RAW_URL"
    echo ""

    echo "Checks:"

    if [ -d "$RUNE_HOME" ]; then
      doctor_ok "Rune home exists"
    else
      doctor_fail "Rune home does not exist: $RUNE_HOME"
    fi

    if [ -d "$RUNE_BIN" ]; then
      doctor_ok "Rune bin directory exists"
    else
      doctor_fail "Rune bin directory does not exist: $RUNE_BIN"
    fi

    if [ -f "$RUNE_EXEC" ]; then
      doctor_ok "Rune executable exists"
    else
      doctor_fail "Rune executable does not exist: $RUNE_EXEC"
    fi

    if [ -x "$RUNE_EXEC" ]; then
      doctor_ok "Rune executable is executable"
    else
      doctor_fail "Rune executable is not executable"
    fi

    if [ -d "$RUNE_DIR" ]; then
      doctor_ok "Rune runes directory exists"
    else
      doctor_fail "Rune runes directory does not exist: $RUNE_DIR"
    fi

    if command -v curl >/dev/null 2>&1; then
      doctor_ok "curl is available"
    else
      doctor_fail "curl is not available"
    fi

    if command -v "${EDITOR:-vim}" >/dev/null 2>&1; then
      doctor_ok "editor is available: ${EDITOR:-vim}"
    else
      doctor_warn "editor not found: ${EDITOR:-vim}"
    fi

    resolved_rune="$(command -v rune 2>/dev/null || true)"

    if [ -n "$resolved_rune" ]; then
      echo ""
      echo "Resolved command:"
      echo "  rune -> $resolved_rune"

      if [ "$resolved_rune" = "$RUNE_EXEC" ]; then
        doctor_ok "PATH resolves rune to expected executable"
      else
        doctor_warn "PATH resolves rune to a different executable"
        echo "  Expected: $RUNE_EXEC"
        echo "  Actual:   $resolved_rune"
      fi
    else
      doctor_fail "rune is not available in PATH"
    fi

    if echo ":$PATH:" | grep -q ":$RUNE_BIN:"; then
      doctor_ok "Rune bin is in PATH"
    else
      doctor_warn "Rune bin is not in PATH"
      echo "  Add this to your shell config:"
      echo '  export PATH="$HOME/.rune/bin:$PATH"'
    fi

    rune_count=0

    for dir in "$RUNE_DIR"/*; do
      [ -d "$dir" ] || continue
      [ -f "$dir/rune.yaml" ] || continue
      rune_count=$((rune_count + 1))
    done

    echo ""
    echo "Runes:"
    echo "  $rune_count installed"

    echo ""
    echo "Doctor finished."
    echo ""
    ;;

  list)
    echo ""
    echo "Available runes:"
    echo "---------------------------------------------------------------"

    found=false

    printf "  %-20s %-8s %-8s %s\n" "NAME" "RUNTIME" "VERSION" "DESCRIPTION"
    printf "  %-20s %-8s %-8s %s\n" "----" "-------" "-------" "-----------"

    for dir in "$RUNE_DIR"/*; do
      [ -d "$dir" ] || continue

      yaml="$dir/rune.yaml"

      if [ ! -f "$yaml" ]; then
        continue
      fi

      name=$(get_field name "$yaml")
      runtime=$(get_field runtime "$yaml")
      version=$(get_field version "$yaml")
      desc=$(get_field description "$yaml")

      printf "  %-20s %-8s %-8s %s\n" "${name:-$(basename "$dir")}" "${runtime:-unknown}" "${version:-unknown}" "${desc:-No description}"
      found=true
    done

    if [ "$found" = false ]; then
      echo "  No runes found."
    fi

    echo ""
    ;;

  run)
    if [ -z "$target" ]; then
      echo "❌ Missing rune name."
      echo "Run:"
      echo "  rune list"
      exit 1
    fi

    dir="$RUNE_DIR/$target"

    if [ ! -d "$dir" ]; then
      echo "❌ Rune not found: $target"
      echo "Run:"
      echo "  rune list"
      exit 1
    fi

    yaml="$dir/rune.yaml"

    if [ ! -f "$yaml" ]; then
      echo "❌ Missing rune.yaml for: $target"
      echo "Run:"
      echo "  rune validate $target"
      exit 1
    fi

    runtime=$(get_field runtime "$yaml")

    if [ -z "$runtime" ]; then
      echo "❌ Missing runtime in rune.yaml for: $target"
      echo "Run:"
      echo "  rune validate $target"
      exit 1
    fi

    if ! is_supported_runtime "$runtime"; then
      echo "❌ Unsupported runtime: $runtime"
      echo "Run:"
      echo "  rune validate $target"
      exit 1
    fi

    entry=$(get_field entry "$yaml")

    if [ -z "$entry" ]; then
      entry="run"
    fi

    entry_path="$dir/$entry"

    if [ ! -f "$entry_path" ]; then
      echo "❌ Entry file not found: $entry"
      echo "Run:"
      echo "  rune validate $target"
      exit 1
    fi

    if [ ! -x "$entry_path" ]; then
      echo "❌ Entry file is not executable: $entry"
      echo ""
      echo "Fix:"
      echo "  chmod +x \"$entry_path\""
      echo ""
      echo "Or run:"
      echo "  rune validate $target"
      exit 1
    fi

    if ! check_requires "$yaml"; then
      echo ""
      echo "Run:"
      echo "  rune validate $target"
      exit 1
    fi

    echo "▶ Running $target..."
    "$entry_path" "$@"
    ;;

  help)
    if [ -z "$target" ]; then
      print_global_help
      exit 0
    fi

    dir="$RUNE_DIR/$target"

    if [ ! -d "$dir" ]; then
      echo "❌ Rune not found: $target"
      exit 1
    fi

    yaml="$dir/rune.yaml"

    if [ ! -f "$yaml" ]; then
      echo "❌ Missing rune.yaml for: $target"
      exit 1
    fi

    echo ""
    echo "NAME"
    echo "    $(get_field name "$yaml") - $(get_field description "$yaml")"
    echo ""

    echo "USAGE"
    print_block usage "$yaml"
    echo ""

    echo "OPTIONS"
    print_block options "$yaml"
    echo ""

    echo "EXAMPLES"
    print_block examples "$yaml"
    echo ""
    ;;

  info)
    if [ -z "$target" ]; then
      echo "❌ Missing rune name."
      echo "Run:"
      echo "  rune list"
      exit 1
    fi

    dir="$RUNE_DIR/$target"
    yaml="$dir/rune.yaml"

    echo ""
    echo "Rune Info"
    echo "=================================="
    echo ""

    if [ ! -d "$dir" ]; then
      echo "❌ Rune not found: $target"
      echo ""
      exit 1
    fi

    if [ ! -f "$yaml" ]; then
      echo "❌ Missing rune.yaml for: $target"
      echo ""
      exit 1
    fi

    name=$(get_field name "$yaml")
    version=$(get_field version "$yaml")
    description=$(get_field description "$yaml")
    runtime=$(get_field runtime "$yaml")
    entry=$(get_field entry "$yaml")
    schema_version=$(get_field schema_version "$yaml")

    if [ -z "$entry" ]; then
      entry="run"
    fi

    entry_path="$dir/$entry"

    echo "Name:"
    echo "  ${name:-$target}"
    echo ""

    echo "Description:"
    echo "  ${description:-No description}"
    echo ""

    echo "Version:"
    echo "  ${version:-unknown}"
    echo ""

    echo "Schema version:"
    echo "  ${schema_version:-unknown}"
    echo ""

    echo "Runtime:"
    echo "  ${runtime:-unknown}"
    echo ""

    echo "Entry:"
    echo "  $entry"
    echo ""

    echo "Path:"
    echo "  $dir"
    echo ""

    echo "Entry path:"
    echo "  $entry_path"
    echo ""

    echo "Requires:"
    deps=$(get_requires "$yaml")

    if [ -z "$deps" ]; then
      echo "  none"
    else
      while IFS= read -r dep; do
        [ -z "$dep" ] && continue
        echo "  $dep"
      done <<< "$deps"
    fi

    echo ""
    echo "Status:"

    if [ -f "$yaml" ]; then
      doctor_ok "rune.yaml exists"
    else
      doctor_fail "rune.yaml missing"
    fi

    if [ -f "$entry_path" ]; then
      doctor_ok "entry file exists"
    else
      doctor_fail "entry file missing: $entry"
    fi

    if [ -x "$entry_path" ]; then
      doctor_ok "entry file is executable"
    else
      doctor_warn "entry file is not executable"
    fi

    if [ -n "$deps" ]; then
      while IFS= read -r dep; do
        [ -z "$dep" ] && continue

        if command -v "$dep" >/dev/null 2>&1; then
          doctor_ok "dependency available: $dep"
        else
          doctor_fail "dependency missing: $dep"
        fi
      done <<< "$deps"
    fi

    echo ""
    ;;

  validate)
    if [ "$target" = "--all" ]; then
      echo ""
      echo "Rune Validate All"
      echo "=================================="
      echo ""

      valid=0
      invalid=0
      total=0
      found=false

      for dir in "$RUNE_DIR"/*; do
        [ -d "$dir" ] || continue

        rune_name="$(basename "$dir")"

        if [ ! -f "$dir/rune.yaml" ]; then
          continue
        fi

        found=true
        total=$((total + 1))

        if validate_rune_quiet "$rune_name"; then
          echo "✅ $rune_name"
          valid=$((valid + 1))
        else
          echo "❌ $rune_name"
          invalid=$((invalid + 1))
        fi
      done

      if [ "$found" = false ]; then
        echo "No runes found."
        echo ""
        exit 0
      fi

      echo ""
      echo "Summary:"
      echo "  Valid:   $valid"
      echo "  Invalid: $invalid"
      echo "  Total:   $total"
      echo ""

      if [ "$invalid" -eq 0 ]; then
        echo "✅ All runes are valid."
        echo ""
        exit 0
      else
        echo "❌ Some runes are invalid."
        echo ""
        echo "Run:"
        echo "  rune validate <name>"
        echo ""
        exit 1
      fi
    fi

    if [ -z "$target" ]; then
      echo "❌ Missing rune name."
      echo "Run:"
      echo "  rune list"
      echo "  rune validate --all"
      exit 1
    fi

    dir="$RUNE_DIR/$target"
    yaml="$dir/rune.yaml"

    errors=0
    warnings=0

    echo ""
    echo "Rune Validate"
    echo "=================================="
    echo ""

    echo "Target:"
    echo "  $target"
    echo ""

    echo "Checks:"

    if [ -d "$dir" ]; then
      doctor_ok "rune directory exists"
    else
      doctor_fail "rune directory missing: $dir"
      echo ""
      exit 1
    fi

    if [ -f "$yaml" ]; then
      doctor_ok "rune.yaml exists"
    else
      doctor_fail "rune.yaml missing: $yaml"
      echo ""
      exit 1
    fi

    echo ""
    echo "Required fields:"

    validate_field "schema_version" "$yaml" || errors=$((errors + 1))
    validate_field "name" "$yaml" || errors=$((errors + 1))
    validate_field "version" "$yaml" || errors=$((errors + 1))
    validate_field "description" "$yaml" || errors=$((errors + 1))
    validate_field "runtime" "$yaml" || errors=$((errors + 1))
    validate_field "entry" "$yaml" || errors=$((errors + 1))

    name=$(get_field name "$yaml")
    runtime=$(get_field runtime "$yaml")
    entry=$(get_field entry "$yaml")
    schema_version=$(get_field schema_version "$yaml")

    if [ -z "$entry" ]; then
      entry="run"
    fi

    entry_path="$dir/$entry"

    echo ""
    echo "Manifest consistency:"

    if [ -n "$schema_version" ] && [ "$schema_version" != "1" ]; then
      doctor_warn "unsupported schema_version: $schema_version"
      echo "  Current supported schema_version: 1"
      warnings=$((warnings + 1))
    elif [ "$schema_version" = "1" ]; then
      doctor_ok "schema_version is supported: $schema_version"
    fi

    if [ -n "$name" ] && [ "$name" != "$target" ]; then
      doctor_warn "manifest name differs from directory name"
      echo "  Directory: $target"
      echo "  Manifest:  $name"
      warnings=$((warnings + 1))
    else
      doctor_ok "manifest name matches directory name"
    fi

    case "$runtime" in
      bash|python|node|ruby|swift|go|"")
        if [ -n "$runtime" ]; then
          doctor_ok "runtime is supported by current manifest format: $runtime"
        fi
        ;;
      *)
        doctor_warn "unknown runtime: $runtime"
        warnings=$((warnings + 1))
        ;;
    esac

    echo ""
    echo "Entry:"

    if [ -f "$entry_path" ]; then
      doctor_ok "entry file exists: $entry"
    else
      doctor_fail "entry file missing: $entry"
      errors=$((errors + 1))
    fi

    if [ -f "$entry_path" ]; then
      if [ -x "$entry_path" ]; then
        doctor_ok "entry file is executable"
      else
        doctor_warn "entry file is not executable"
        echo "  Fix:"
        echo "  chmod +x \"$entry_path\""
        warnings=$((warnings + 1))
      fi
    fi

    echo ""
    echo "Requires:"

    deps=$(get_requires "$yaml")

    if [ -z "$deps" ]; then
      doctor_ok "no dependencies declared"
    else
      while IFS= read -r dep; do
        [ -z "$dep" ] && continue

        if command -v "$dep" >/dev/null 2>&1; then
          doctor_ok "dependency available: $dep"
        else
          doctor_fail "dependency missing: $dep"
          errors=$((errors + 1))
        fi
      done <<< "$deps"
    fi

    echo ""
    echo "Help blocks:"

    block_exists "usage" "$yaml" || warnings=$((warnings + 1))
    block_exists "options" "$yaml" || warnings=$((warnings + 1))
    block_exists "examples" "$yaml" || warnings=$((warnings + 1))

    echo ""
    echo "Summary:"
    echo "  Errors:   $errors"
    echo "  Warnings: $warnings"
    echo ""

    if [ "$errors" -eq 0 ]; then
      echo "✅ Rune is valid."
      echo ""
      exit 0
    else
      echo "❌ Rune is invalid."
      echo ""
      exit 1
    fi
    ;;

  add)
    read -p "Name: " name
    read -p "Description: " description
    read -p "Runtime (bash/python/node/ruby/swift/go) [bash]: " runtime

    runtime=${runtime:-bash}

    if [ -z "$name" ]; then
      echo "❌ Name is required."
      exit 1
    fi

    if ! is_valid_rune_name "$name"; then
      echo "❌ Invalid rune name: $name"
      echo ""
      echo "Use only letters, numbers, dash and underscore."
      echo "Examples:"
      echo "  clean-derived-data"
      echo "  push_notification"
      echo "  txt-to-sqlite"
      echo ""
      exit 1
    fi

    if ! is_supported_runtime "$runtime"; then
      echo "❌ Unsupported runtime: $runtime"
      echo ""
      echo "Supported runtimes:"
      echo "  bash"
      echo "  python"
      echo "  node"
      echo "  ruby"
      echo "  swift"
      echo "  go"
      echo ""
      exit 1
    fi

    if [ -z "$description" ]; then
      description="Reusable automation script"
    fi

    dir="$RUNE_DIR/$name"

    if [ -d "$dir" ]; then
      echo "❌ Rune already exists: $name"
      exit 1
    fi

    mkdir -p "$dir"

    cat > "$dir/rune.yaml" <<EOF
schema_version: 1
name: $name
version: 1.0.0
description: $description

requires: []

usage: |
  rune run $name [options]

options: |
  --help     Show help

examples: |
  rune run $name

runtime: $runtime
entry: run
EOF

    case "$runtime" in
      bash)
        cat > "$dir/run" <<EOF
#!/bin/bash
set -e

show_help() {
  echo "Usage:"
  echo "  rune run $name [options]"
  echo ""
  echo "Options:"
  echo "  --help     Show help"
}

case "\${1:-}" in
  --help|-h)
    show_help
    exit 0
    ;;
esac

# $description

echo "Hello from $name"
EOF
        ;;

      python)
        cat > "$dir/run" <<EOF
#!/usr/bin/env python3
import sys

def show_help():
    print("Usage:")
    print("  rune run $name [options]")
    print()
    print("Options:")
    print("  --help     Show help")

if len(sys.argv) > 1 and sys.argv[1] in ("--help", "-h"):
    show_help()
    sys.exit(0)

# $description

print("Hello from $name")
EOF
        ;;

      node)
        cat > "$dir/run" <<EOF
#!/usr/bin/env node

function showHelp() {
  console.log("Usage:");
  console.log("  rune run $name [options]");
  console.log("");
  console.log("Options:");
  console.log("  --help     Show help");
}

if (process.argv[2] === "--help" || process.argv[2] === "-h") {
  showHelp();
  process.exit(0);
}

// $description

console.log("Hello from $name");
EOF
        ;;

      ruby)
        cat > "$dir/run" <<EOF
#!/usr/bin/env ruby

def show_help
  puts "Usage:"
  puts "  rune run $name [options]"
  puts ""
  puts "Options:"
  puts "  --help     Show help"
end

if ARGV[0] == "--help" || ARGV[0] == "-h"
  show_help
  exit 0
end

# $description

puts "Hello from $name"
EOF
        ;;

      swift)
        cat > "$dir/run" <<EOF
#!/usr/bin/env swift

import Foundation

func showHelp() {
    print("Usage:")
    print("  rune run $name [options]")
    print("")
    print("Options:")
    print("  --help     Show help")
}

if CommandLine.arguments.dropFirst().first == "--help" || CommandLine.arguments.dropFirst().first == "-h" {
    showHelp()
    exit(0)
}

// $description

print("Hello from $name")
EOF
        ;;

      go)
        cat > "$dir/run" <<EOF
#!/usr/bin/env bash
set -e

echo "This rune uses Go."
echo ""
echo "Suggested structure:"
echo "  main.go"
echo ""
echo "Next steps:"
echo "  rune edit $name"
EOF
        ;;
    esac

    chmod +x "$dir/run"

    echo ""
    echo "Opening entry file..."
    ${EDITOR:-vim} "$dir/run"

    echo ""
    echo "✅ Rune '$name' created."
    echo ""
    echo "Next steps:"
    echo "  rune validate $name"
    echo "  rune run $name"
    echo "  rune help $name"
    echo ""
    ;;

  edit)
    if [ -z "$target" ]; then
      echo "❌ Missing rune name."
      echo "Run:"
      echo "  rune list"
      exit 1
    fi

    dir="$RUNE_DIR/$target"

    if [ ! -d "$dir" ]; then
      echo "❌ Rune not found: $target"
      exit 1
    fi

    yaml="$dir/rune.yaml"

    if [ ! -f "$yaml" ]; then
      echo "❌ Missing rune.yaml for: $target"
      exit 1
    fi

    entry=$(get_field entry "$yaml")

    if [ -z "$entry" ]; then
      entry="run"
    fi

    case "$1" in
      --config)
        ${EDITOR:-vim} "$yaml"
        ;;
      --all)
        ${EDITOR:-vim} "$dir"
        ;;
      *)
        ${EDITOR:-vim} "$dir/$entry"
        ;;
    esac
    ;;

  remove)
    if [ -z "$target" ]; then
      echo "❌ Missing rune name."
      echo "Run:"
      echo "  rune list"
      exit 1
    fi

    dir="$RUNE_DIR/$target"

    if [ ! -d "$dir" ]; then
      echo "❌ Rune not found: $target"
      exit 1
    fi

    if [ "$1" != "--force" ]; then
      echo ""
      echo "This will permanently delete rune '$target':"
      echo "  $dir"
      echo ""
      read -p "Continue? [y/N]: " confirm

      case "$confirm" in
        y|Y|yes|YES)
          ;;
        *)
          echo "Cancelled."
          exit 0
          ;;
      esac
    fi

    rm -rf "$dir"
    echo "🗑 Rune '$target' removed."
    ;;

  update)
    echo ""
    echo "Updating Rune..."

    if ! command -v curl >/dev/null 2>&1; then
      echo "❌ curl not found."
      exit 1
    fi

    tmp_file="$(mktemp)"

    if ! curl -fsSL "$RUNE_REPO_RAW_URL/bin/rune" -o "$tmp_file"; then
      echo "❌ Failed to download latest Rune."
      rm -f "$tmp_file"
      exit 1
    fi

    if ! grep -q "RUNE_VERSION=" "$tmp_file"; then
      echo "❌ Downloaded file does not look like Rune."
      rm -f "$tmp_file"
      exit 1
    fi

    chmod +x "$tmp_file"

    if [ -f "$RUNE_EXEC" ]; then
      cp "$RUNE_EXEC" "$RUNE_EXEC.backup"
    fi

    mv "$tmp_file" "$RUNE_EXEC"
    chmod +x "$RUNE_EXEC"

    echo "✅ Rune updated."
    echo ""
    echo "Backup saved to:"
    echo "  $RUNE_EXEC.backup"
    echo ""

    echo "Installed version:"
    "$RUNE_EXEC" version
    echo ""
    ;;

  *)
    echo ""
    echo "❌ Unknown command: $command"
    echo "Run:"
    echo "  rune help"
    echo ""
    exit 1
    ;;
esac
