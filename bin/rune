#!/bin/bash
set -e

# =========================
# Rune paths
# =========================

RUNE_HOME="$HOME/.rune"
RUNE_BIN="$RUNE_HOME/bin"
RUNE_EXEC="$RUNE_BIN/rune"
RUNE_DIR="$RUNE_HOME/runes"

RUNE_VERSION="0.3.0"
RUNE_REPO_RAW_URL="https://raw.githubusercontent.com/zeidle/rune/main"

mkdir -p "$RUNE_BIN"
mkdir -p "$RUNE_DIR"

command="$1"
target="$2"
shift 2 2>/dev/null || true

# =========================
# Helpers
# =========================

get_field() {
  grep "^$1:" "$2" | cut -d' ' -f2-
}

print_block() {
  awk "/^$1: \|/{flag=1;next}/^[^ ]/{flag=0}flag" "$2" | sed 's/^  //'
}

check_requires() {
  local file="$1"
  local deps

  deps=$(awk '/^requires:/,/^[^ ]/' "$file" | grep "-" | sed 's/- //') || true

  for dep in $deps; do
    if ! command -v "$dep" >/dev/null 2>&1; then
      echo "❌ Missing dependency: $dep"
      exit 1
    fi
  done
}

print_global_help() {
  echo ""
  echo "Rune CLI $RUNE_VERSION"
  echo "=================================="
  echo ""
  echo "Usage:"
  echo "  rune <command> [options]"
  echo ""
  echo "Commands:"
  echo "  list                   List available runes"
  echo "  run <name> [args...]   Run a rune"
  echo "  help <name>            Show help for a rune"
  echo "  add                    Create new rune"
  echo "  edit <name>            Edit rune entry file"
  echo "  edit <name> --config   Edit rune.yaml"
  echo "  edit <name> --all      Open rune directory"
  echo "  remove <name>          Delete rune"
  echo "  update                 Update Rune CLI"
  echo "  version                Show Rune version"
  echo "  doctor                 Check Rune installation"
  echo ""
  echo "Examples:"
  echo "  rune list"
  echo "  rune run ios-run --scheme App"
  echo "  rune help ios-run"
  echo "  rune update"
  echo "  rune version"
  echo "  rune doctor"
  echo ""
}

doctor_ok() {
  echo "✅ $1"
}

doctor_warn() {
  echo "⚠️  $1"
}

doctor_fail() {
  echo "❌ $1"
}

# =========================
# Commands
# =========================

case "$command" in

  ""|--help|-h)
    print_global_help
    ;;

  version|--version|-v)
    echo "Rune $RUNE_VERSION"
    ;;

  doctor)
    echo ""
    echo "Rune Doctor"
    echo "=================================="
    echo ""

    echo "Version:"
    echo "  Rune $RUNE_VERSION"
    echo ""

    echo "Paths:"
    echo "  RUNE_HOME: $RUNE_HOME"
    echo "  RUNE_BIN:  $RUNE_BIN"
    echo "  RUNE_EXEC: $RUNE_EXEC"
    echo "  RUNE_DIR:  $RUNE_DIR"
    echo ""

    echo "Update source:"
    echo "  $RUNE_REPO_RAW_URL"
    echo ""

    echo "Checks:"

    if [ -d "$RUNE_HOME" ]; then
      doctor_ok "Rune home exists"
    else
      doctor_fail "Rune home does not exist: $RUNE_HOME"
    fi

    if [ -d "$RUNE_BIN" ]; then
      doctor_ok "Rune bin directory exists"
    else
      doctor_fail "Rune bin directory does not exist: $RUNE_BIN"
    fi

    if [ -f "$RUNE_EXEC" ]; then
      doctor_ok "Rune executable exists"
    else
      doctor_fail "Rune executable does not exist: $RUNE_EXEC"
    fi

    if [ -x "$RUNE_EXEC" ]; then
      doctor_ok "Rune executable is executable"
    else
      doctor_fail "Rune executable is not executable"
    fi

    if [ -d "$RUNE_DIR" ]; then
      doctor_ok "Rune runes directory exists"
    else
      doctor_fail "Rune runes directory does not exist: $RUNE_DIR"
    fi

    if command -v curl >/dev/null 2>&1; then
      doctor_ok "curl is available"
    else
      doctor_fail "curl is not available"
    fi

    if command -v "${EDITOR:-vim}" >/dev/null 2>&1; then
      doctor_ok "editor is available: ${EDITOR:-vim}"
    else
      doctor_warn "editor not found: ${EDITOR:-vim}"
    fi

    resolved_rune="$(command -v rune 2>/dev/null || true)"

    if [ -n "$resolved_rune" ]; then
      echo ""
      echo "Resolved command:"
      echo "  rune -> $resolved_rune"

      if [ "$resolved_rune" = "$RUNE_EXEC" ]; then
        doctor_ok "PATH resolves rune to expected executable"
      else
        doctor_warn "PATH resolves rune to a different executable"
        echo "  Expected: $RUNE_EXEC"
        echo "  Actual:   $resolved_rune"
      fi
    else
      doctor_fail "rune is not available in PATH"
    fi

    if echo ":$PATH:" | grep -q ":$RUNE_BIN:"; then
      doctor_ok "Rune bin is in PATH"
    else
      doctor_warn "Rune bin is not in PATH"
      echo "  Add this to your shell config:"
      echo '  export PATH="$HOME/.rune/bin:$PATH"'
    fi

    rune_count=0

    for dir in "$RUNE_DIR"/*; do
      [ -d "$dir" ] || continue
      [ -f "$dir/rune.yaml" ] || continue
      rune_count=$((rune_count + 1))
    done

    echo ""
    echo "Runes:"
    echo "  $rune_count installed"

    echo ""
    echo "Doctor finished."
    echo ""
    ;;

  list)
    echo ""
    echo "Available runes:"
    echo "-----------------------------------"

    found=false

    for dir in "$RUNE_DIR"/*; do
      [ -d "$dir" ] || continue

      yaml="$dir/rune.yaml"

      if [ ! -f "$yaml" ]; then
        continue
      fi

      name=$(get_field name "$yaml")
      desc=$(get_field description "$yaml")

      printf "  %-20s %s\n" "$name" "$desc"
      found=true
    done

    if [ "$found" = false ]; then
      echo "  No runes found."
    fi

    echo ""
    ;;

  run)
    if [ -z "$target" ]; then
      echo "❌ Missing rune name."
      echo "Run:"
      echo "  rune list"
      exit 1
    fi

    dir="$RUNE_DIR/$target"

    if [ ! -d "$dir" ]; then
      echo "❌ Rune not found: $target"
      exit 1
    fi

    yaml="$dir/rune.yaml"

    if [ ! -f "$yaml" ]; then
      echo "❌ Missing rune.yaml for: $target"
      exit 1
    fi

    entry=$(get_field entry "$yaml")

    if [ -z "$entry" ]; then
      entry="run"
    fi

    entry_path="$dir/$entry"

    if [ ! -f "$entry_path" ]; then
      echo "❌ Entry file not found: $entry"
      exit 1
    fi

    if [ ! -x "$entry_path" ]; then
      chmod +x "$entry_path"
    fi

    check_requires "$yaml"

    echo "▶ Running $target..."
    "$entry_path" "$@"
    ;;

  help)
    if [ -z "$target" ]; then
      print_global_help
      exit 0
    fi

    dir="$RUNE_DIR/$target"

    if [ ! -d "$dir" ]; then
      echo "❌ Rune not found: $target"
      exit 1
    fi

    yaml="$dir/rune.yaml"

    if [ ! -f "$yaml" ]; then
      echo "❌ Missing rune.yaml for: $target"
      exit 1
    fi

    echo ""
    echo "NAME"
    echo "    $(get_field name "$yaml") - $(get_field description "$yaml")"
    echo ""

    echo "SYNOPSIS"
    print_block usage "$yaml"
    echo ""

    echo "OPTIONS"
    print_block options "$yaml"
    echo ""

    echo "EXAMPLES"
    print_block examples "$yaml"
    echo ""
    ;;

  add)
    read -p "Name: " name
    read -p "Description: " description
    read -p "Runtime (bash/python) [bash]: " runtime

    runtime=${runtime:-bash}
    dir="$RUNE_DIR/$name"

    if [ -z "$name" ]; then
      echo "❌ Name is required."
      exit 1
    fi

    if [ -d "$dir" ]; then
      echo "❌ Rune already exists: $name"
      exit 1
    fi

    mkdir -p "$dir"

    cat > "$dir/rune.yaml" <<EOF
name: $name
version: 1.0.0
description: $description

requires: []

usage: |
  rune run $name

options: |

examples: |

runtime: $runtime
entry: run
EOF

    cat > "$dir/run" <<EOF
#!/bin/bash
set -e

# $description

echo "Hello from $name"
EOF

    chmod +x "$dir/run"

    echo ""
    echo "Opening entry file..."
    ${EDITOR:-vim} "$dir/run"

    echo ""
    echo "✅ Rune '$name' created."
    ;;

  edit)
    if [ -z "$target" ]; then
      echo "❌ Missing rune name."
      echo "Run:"
      echo "  rune list"
      exit 1
    fi

    dir="$RUNE_DIR/$target"

    if [ ! -d "$dir" ]; then
      echo "❌ Rune not found: $target"
      exit 1
    fi

    yaml="$dir/rune.yaml"

    if [ ! -f "$yaml" ]; then
      echo "❌ Missing rune.yaml for: $target"
      exit 1
    fi

    entry=$(get_field entry "$yaml")

    if [ -z "$entry" ]; then
      entry="run"
    fi

    case "$1" in
      --config)
        ${EDITOR:-vim} "$yaml"
        ;;
      --all)
        ${EDITOR:-vim} "$dir"
        ;;
      *)
        ${EDITOR:-vim} "$dir/$entry"
        ;;
    esac
    ;;

  remove)
    if [ -z "$target" ]; then
      echo "❌ Missing rune name."
      echo "Run:"
      echo "  rune list"
      exit 1
    fi

    dir="$RUNE_DIR/$target"

    if [ -d "$dir" ]; then
      rm -rf "$dir"
      echo "🗑 Rune '$target' removed."
    else
      echo "❌ Rune not found: $target"
      exit 1
    fi
    ;;

  update)
    echo ""
    echo "Updating Rune..."

    if ! command -v curl >/dev/null 2>&1; then
      echo "❌ curl not found."
      exit 1
    fi

    tmp_file="$(mktemp)"

    if ! curl -fsSL "$RUNE_REPO_RAW_URL/bin/rune" -o "$tmp_file"; then
      echo "❌ Failed to download latest Rune."
      rm -f "$tmp_file"
      exit 1
    fi

    if ! grep -q "RUNE_VERSION=" "$tmp_file"; then
      echo "❌ Downloaded file does not look like Rune."
      rm -f "$tmp_file"
      exit 1
    fi

    chmod +x "$tmp_file"

    if [ -f "$RUNE_EXEC" ]; then
      cp "$RUNE_EXEC" "$RUNE_EXEC.backup"
    fi

    mv "$tmp_file" "$RUNE_EXEC"
    chmod +x "$RUNE_EXEC"

    echo "✅ Rune updated."
    echo ""
    echo "Backup saved to:"
    echo "  $RUNE_EXEC.backup"
    echo ""

    echo "Installed version:"
    "$RUNE_EXEC" version
    echo ""
    ;;

  *)
    echo ""
    echo "❌ Unknown command: $command"
    echo "Run:"
    echo "  rune help"
    echo ""
    exit 1
    ;;
esac
